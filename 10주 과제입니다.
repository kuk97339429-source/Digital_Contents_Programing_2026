    while (1)
    {
        if (_getch() == ENTER)
            break;
    }
}

// =========================
// 메인 함수
// =========================
int main()
{
    HideCursor();

    // 시작 로고
    LogoScreen();

    int menu = 0;

    char* title[4] = {
        "게임 시작",
        "게임 종료",
        "만든 사람",
        "사용 설명서"
    };

    while (1)
    {
        system("cls");

        // 게임 로고
        SetColor(13);

        printf("\n\n");

        printf("     #################################\n");
        printf("     #                               #\n");
        printf("     #          F는 못 받아          #\n");
        printf("     #                               #\n");
        printf("     #################################\n\n");

        // 메뉴 출력
        for (int i = 0; i < 4; i++)
        {
            if (menu == i)
            {
                SetColor(12);

                printf("            > %s <\n", title[i]);
            }
            else
            {
                SetColor(7);

                printf("              %s\n", title[i]);
            }
        }

        int key = _getch();

        // 방향키 입력
        if (key == 224)
        {
            key = _getch();

            // 위 방향키
            if (key == KEY_UP)
            {
                menu--;

                if (menu < 0)
                    menu = 3;
            }

            // 아래 방향키
            else if (key == KEY_DOWN)
            {
                menu++;

                if (menu > 3)
                    menu = 0;
            }
        }

        // 엔터 입력
        else if (key == ENTER)
        {
            switch (menu)
            {
                // 게임 시작
            case 0:

                system("cls");

                SetColor(10);

                printf("\n\n");
                printf("          게임 시작!\n");

                Sleep(1000);

                break;

                // 게임 종료
            case 1:

                system("cls");

                SetColor(12);

                printf("\n\n");
                printf("          게임을 종료합니다.\n");

                Sleep(1000);

                return 0;

                // 만든 사람
            case 2:

                TeamPage();

                break;

                // 사용 설명서
            case 3:

                HelpPage();

                break;
            }
        }
    }

    return 0;
}


